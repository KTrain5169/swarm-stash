# Discord OAuth — create an app at https://discord.com/developers/applications
# then add the redirect URL:  <BASE_URL>/auth/discord/callback
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Public base URL of the site (must match the redirect you registered on Discord)
BASE_URL=http://localhost:3000
PORT=3000

# Random string used to sign session cookies (generate with: openssl rand -hex 32).
# If unset, a random one is used per start — sessions then reset on restart.
SESSION_SECRET=

# Allow the no-Discord dev login even when Discord is configured (1 = yes).
# Dev login is automatically enabled whenever Discord credentials are missing.
ALLOW_DEV_LOGIN=

# Meme submission moderators: comma-separated Discord user IDs (or dev-login
# names). When set, submitted memes wait in a review queue these users can see.
# When empty, submissions are minted as cards instantly (fine for local play).
ADMINS=
